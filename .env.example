# ── Local development ──────────────────────────────────────────────────────────
DATABRIEF_ENV=development
DATABRIEF_CORS_ORIGINS=http://localhost:3000
DATABRIEF_MAX_UPLOAD_MB=5
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ── Vercel production ──────────────────────────────────────────────────────────
# Set these in Vercel project settings (Environment Variables tab).
# DATABRIEF_ENV=production
# DATABRIEF_MAX_UPLOAD_MB=5
# DATABRIEF_CORS_ORIGINS=https://<your-domain>.vercel.app
# NEXT_PUBLIC_API_BASE_URL=/backend
